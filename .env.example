# ============================
# ConfecçãoPRO — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================

# Database (usado pelo backend Go)
DATABASE_URL=postgres://confeccao:senha123@localhost:5432/confeccaopro?sslmode=disable
DB_USER=confeccao
DB_PASSWORD=senha123
DB_NAME=confeccaopro

# Supabase — obtenha em https://supabase.com/dashboard
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# JWT (usado pelo middleware Go para validar tokens Supabase)
JWT_SECRET=your-supabase-jwt-secret

# Frontend (prefixo NEXT_PUBLIC_ = exposto ao browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8080

# Vercel (só necessário para deploy via GitHub Actions)
# VERCEL_TOKEN=
# VERCEL_ORG_ID=
# VERCEL_PROJECT_ID=
